# @supabase/server — required
SUPABASE_URL=https://lzfnluxdwmzqbpzxnige.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=https://lzfnluxdwmzqbpzxnige.supabase.co/auth/v1/.well-known/jwks.json

# Next.js proxy runs on Edge and only reads NEXT_PUBLIC_* vars.
# Set these to the same values as above.
NEXT_PUBLIC_SUPABASE_URL=https://lzfnluxdwmzqbpzxnige.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Database — Supabase → Settings → Database → Connection string
# URL-encode special characters in the password (@ → %40).
#
# App runtime (Next.js): Transaction pooler on port 6543 — required for dev/serverless.
# Migrations (npm run db:migrate): Session pooler :5432 or Direct connection is fine.
# The app auto-upgrades pooler :5432 → :6543 if you paste the Session URI by mistake.
#
# If your shell exports DATABASE_URL, unset it before `npm run dev` or it overrides .env.local.
DATABASE_URL=postgresql://postgres.lzfnluxdwmzqbpzxnige:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Application
APP_VERSION=0.1.0
LOG_LEVEL=info

# AI categorization (Run AI in Workshop)
OPENAI_API_KEY=

# Optional ABRD project catalog (import wizard project search)
ABRD_API_BASE_URL=
ABRD_API_TOKEN=

# Legacy alias (optional)
AI_API_KEY=
AI_PROVIDER=openai
